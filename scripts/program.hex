00000820 // add $1, $0, $0 # $1 = 0 (Current Fib)
20020001 // addi $2, $0, 1 # $2 = 1 (Next Fib)
00001820 // add $3, $0, $0 # $3 = 0 (Memory Address Pointer)
20040054 // addi $4, $0, 84 # $4 = 40 (Loop Limit: 10 numbers * 4 bytes)
10640006 // loop: beq $3, $4, 6 # If Pointer == 40, jump forward 6 instructions to 'exit'
AC610000 // sw $1, 0($3) # Store Current Fib to Data Memory
00222820 // add $5, $1, $2 # Temp = Current + Next
00020820 // add $1, $0, $2 # Current = Next
00051020 // add $2, $0, $5 # Next = Temp
20630004 // addi $3, $3, 4 # Pointer = Pointer + 4
1000FFF9 // beq $0, $0, -7 # Unconditional jump backward 7 instructions to 'loop'
1000FFFF // exit: beq $0, $0, -1 # Infinite trap
